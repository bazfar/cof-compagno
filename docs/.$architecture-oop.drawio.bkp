        <mxCell id="entite" value="&lt;b&gt;Entite&lt;/b&gt; «abstraite»&lt;hr&gt;# nom&lt;br&gt;# pvMax / pvActuel&lt;br&gt;# def&lt;hr&gt;+ subirDegats(n)&lt;br&gt;+ soigner(n)&lt;br&gt;+ estVivant() : bool" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="340" y="90" width="270" height="150" as="geometry" />
        </mxCell>
        <mxCell id="perso" value="&lt;b&gt;Personnage&lt;/b&gt; → Entite&lt;hr&gt;- classe, race, niveau&lt;br&gt;- caracs, capacites[]&lt;br&gt;- portrait, inventaire&lt;hr&gt;+ calculerPV() / calculerDEF()&lt;br&gt;+ bonusAttaque(type)&lt;br&gt;+ monterNiveau()&lt;br&gt;+ versJSON() / depuisJSON()" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
