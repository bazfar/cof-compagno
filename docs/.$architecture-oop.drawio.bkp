<mxfile host="app.diagrams.net" type="device">
  <diagram name="Architecture OOP cible - COF Compagnon" id="oop-cof-2">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2300" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
