        <mxCell id="legende" value="Bleu = Entites combat  |  Vert = Donnees/Modeles  |  Rose = Session (etat partage)  |  Orange = Cartes  |  Gris = Persistance  |  Violet = App/UI        (triangle creux = heritage ; pointille+triangle = implemente ; losange = agregation ; pointille = dependance)" style="text;html=1;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="42" width="1700" height="20" as="geometry" />
        </mxCell>

        <mxCell id="depot" value="&lt;b&gt;Depot&lt;/b&gt; «interface»&lt;hr&gt;+ charger(id)&lt;br&gt;+ sauver(obj)&lt;br&gt;+ supprimer(id)&lt;br&gt;+ ecouter(cb)  // temps reel" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
