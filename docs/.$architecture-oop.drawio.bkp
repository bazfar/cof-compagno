        <mxCell id="titre" value="Architecture OOP cible (scalable : sessions multijoueur + combat partage) - COF Compagnon" style="text;html=1;align=left;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="14" width="1200" height="28" as="geometry" />
